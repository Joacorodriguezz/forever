generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum EstadoDeportista {
  EN_DEUDA    @map("En deuda")
  AL_DIA      @map("Al dia")
  MOROSA      @map("Morosa")
  INACTIVA    @map("Inactiva")
}

enum EstadoCuota {
  PAGADA      @map("Pagada")
  PENDIENTE   @map("Pendiente")
  VENCIDA     @map("Vencida")
}

enum EstadoPago {
  APROBADO    @map("Aprobado")
  RECHAZADO   @map("Rechazado")
  PENDIENTE   @map("Pendiente")
}

enum Rol {
  ADMIN           @map("Admin")
  ADMINISTRATIVO  @map("Administrativo")
  DEPORTISTA      @map("Deportista")
}

enum Vinculo {
  PADRE    @map("Padre")
  MADRE    @map("Madre")
  HIJO     @map("Hijo")
  HERMANO  @map("Hermano")
  OTRO     @map("Otro")
}

enum Periodicidad {
  MENSUAL   @map("Mensual")
  ANUAL     @map("Anual")
}

// =============================================================================
// MODELOS BASE (Localidad y Domicilio eliminados)
// =============================================================================



model Disciplina {
  id             Int            @id @default(autoincrement()) @map("id_disciplina")
  nombre         String         @unique
  descripcion    String?
  precioMensual  Decimal        @map("precio_mensual") @db.Decimal(10, 2)
  activa         Boolean        @default(true)
  deportistas    Deportista[]
  cuotas         Cuota[]
  subcategorias  Subcategoria[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("disciplinas")
}

// =============================================================================
// CLASIFICACIÓN DEPORTIVA
// =============================================================================

model Genero {
  id            Int            @id @default(autoincrement()) @map("id_genero")
  nombre        String         @unique
  deportistas   Deportista[]
  subcategorias Subcategoria[]

  @@map("generos")
}

model Categoria {
  id            Int            @id @default(autoincrement()) @map("id_categoria")
  nombre        String         @unique
  deportistas   Deportista[]
  subcategorias Subcategoria[]

  @@map("categorias")
}

model Subcategoria {
  id           Int          @id @default(autoincrement()) @map("id_subcategoria")
  nombre       String
  disciplinaId Int          @map("id_disciplina")
  disciplina   Disciplina   @relation(fields: [disciplinaId], references: [id])
  categoriaId  Int          @map("id_categoria")
  categoria    Categoria    @relation(fields: [categoriaId], references: [id])
  generoId     Int?         @map("id_genero")
  genero       Genero?      @relation(fields: [generoId], references: [id])
  deportistas  Deportista[]

  @@unique([disciplinaId, categoriaId, generoId, nombre])
  @@map("subcategorias")
}

// =============================================================================
// USUARIOS Y AUTENTICACIÓN
// =============================================================================

model CuentaUsuario {
  id              Int             @id @default(autoincrement()) @map("id_cuenta")
  email           String          @unique
  password        String
  rol             Rol             @default(DEPORTISTA)
  activo          Boolean         @default(true)
  intentosFallidos Int            @default(0) @map("intentos_fallidos")
  bloqueadoHasta  DateTime?       @map("bloqueado_hasta")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deportista      Deportista?
  administrativo  Administrativo?

  @@map("cuentas_usuario")
}

model Administrativo {
  id        Int           @id @default(autoincrement()) @map("id_administrativo")
  nombre    String
  apellido  String
  dni       String        @unique
  cuentaId  Int           @unique @map("id_cuenta")
  cuenta    CuentaUsuario @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  noticias  Noticia[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("administrativos")
}

// =============================================================================
// DEPORTISTAS
// =============================================================================

model Deportista {
  id                 Int                       @id @default(autoincrement()) @map("id_deportista")
  nombre             String
  apellido           String
  dni                String                    @unique
  fechaNac           DateTime                  @map("fecha_nac")
  generoId           Int                       @map("id_genero")
  genero             Genero                    @relation(fields: [generoId], references: [id])
  categoriaId        Int                       @map("id_categoria")
  categoria          Categoria                 @relation(fields: [categoriaId], references: [id])
  subcategoriaId     Int?                      @map("id_subcategoria")
  subcategoria       Subcategoria?             @relation(fields: [subcategoriaId], references: [id])
  obraSocial         String?                   @map("obra_social")
  estado             EstadoDeportista          @default(AL_DIA)
  disciplinaId       Int                       @map("id_disciplina")
  disciplina         Disciplina                @relation(fields: [disciplinaId], references: [id])
  cuentaId           Int                       @unique @map("id_cuenta")
  cuenta             CuentaUsuario             @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  enfermedades       String?
  telefonos          String?
  adultoResponsable  AdultoResponsable?
  pagos              Pago[]
  cuotas             Cuota[]
  grupoFamiliar      GrupoFamiliarIntegrante[]
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  @@map("deportistas")
}

model AdultoResponsable {
  id           Int        @id @default(autoincrement()) @map("id_adulto")
  deportistaId Int        @unique @map("id_deportista")
  deportista   Deportista @relation(fields: [deportistaId], references: [id], onDelete: Cascade)
  nombre       String
  apellido     String
  dni          String
  email        String
  telefono     String

  @@map("adultos_responsables")
}

// =============================================================================
// GRUPOS FAMILIARES
// =============================================================================

model GrupoFamiliar {
  id              Int                       @id @default(autoincrement()) @map("id_grupo_familiar")
  nombre          String
  titularDni      String?                   @map("titular_dni")
  cuotaHermano    Decimal?                  @map("cuota_hermano") @db.Decimal(10, 2)
  integrantes     GrupoFamiliarIntegrante[]
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@map("grupos_familiares")
}

model GrupoFamiliarIntegrante {
  grupoId      Int           @map("id_grupo_familiar")
  deportistaId Int           @map("id_deportista")
  vinculo      Vinculo
  esPrincipal  Boolean       @default(false) @map("es_principal")
  grupo        GrupoFamiliar @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  deportista   Deportista    @relation(fields: [deportistaId], references: [id], onDelete: Cascade)

  @@id([grupoId, deportistaId])
  @@map("grupo_familiar_integrantes")
}

// =============================================================================
// CUOTAS Y PAGOS
// =============================================================================

model Cuota {
  id               Int          @id @default(autoincrement()) @map("id_cuota")
  nroCuota         Int          @map("nro_cuota")
  anio             Int          @map("anio")
  monto            Decimal      @db.Decimal(10, 2)
  fechaEmision     DateTime     @map("fecha_emision")
  fechaVencimiento DateTime     @map("fecha_vencimiento")
  estadoCuota      EstadoCuota  @default(PENDIENTE) @map("estado_cuota")
  periodicidad     Periodicidad @default(MENSUAL)
  disciplinaId     Int          @map("id_disciplina")
  disciplina       Disciplina   @relation(fields: [disciplinaId], references: [id])
  deportistaId     Int          @map("id_deportista")
  deportista       Deportista   @relation(fields: [deportistaId], references: [id], onDelete: Cascade)
  pagos            Pago[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([deportistaId, nroCuota, anio, disciplinaId])
  @@map("cuotas")
}

model Pago {
  id                 Int         @id @default(autoincrement()) @map("id_pago")
  fechaPago          DateTime    @map("fecha_pago")
  monto              Decimal     @db.Decimal(10, 2)
  estadoPago         EstadoPago  @default(PENDIENTE) @map("estado_pago")
  medioPago          String?     @map("medio_pago")
  linkComprobante    String?     @map("link_comprobante")
  mercadoPagoId      String?     @unique @map("mercado_pago_id")
  mercadoPagoStatus  String?     @map("mercado_pago_status")
  cuotaId            Int         @map("id_cuota")
  cuota              Cuota       @relation(fields: [cuotaId], references: [id])
  deportistaId       Int         @map("id_deportista")
  deportista         Deportista  @relation(fields: [deportistaId], references: [id], onDelete: Cascade)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@map("pagos")
}

// =============================================================================
// NOTICIAS
// =============================================================================

model Noticia {
  id           Int              @id @default(autoincrement()) @map("id_noticia")
  titulo       String
  fecha        DateTime         @db.Date
  resumen      String           @db.Text
  contenido    String           @db.Text
  autorId      Int?             @map("id_autor")
  autor        Administrativo?  @relation(fields: [autorId], references: [id], onDelete: SetNull)
  imagenes     NoticiaImagen[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("noticias")
}

model NoticiaImagen {
  id         Int      @id @default(autoincrement()) @map("id_imagen")
  noticiaId  Int      @map("id_noticia")
  noticia    Noticia  @relation(fields: [noticiaId], references: [id], onDelete: Cascade)
  url        String   @db.Text
  orden      Int      @default(0)

  @@map("noticia_imagenes")
}
