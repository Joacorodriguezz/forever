generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum EstadoDeportista {
  EN_DEUDA    @map("En deuda")
  AL_DIA      @map("Al dia")
  MOROSA      @map("Morosa")
  INACTIVA    @map("Inactiva")
}

enum EstadoCuota {
  PAGADA      @map("Pagada")
  PENDIENTE   @map("Pendiente")
  VENCIDA     @map("Vencida")
}

enum EstadoPago {
  APROBADO    @map("Aprobado")
  RECHAZADO   @map("Rechazado")
  PENDIENTE   @map("Pendiente")
}

enum Rol {
  ADMIN           @map("Admin")
  ADMINISTRATIVO  @map("Administrativo")
  DEPORTISTA      @map("Deportista")
}

enum Vinculo {
  PADRE    @map("Padre")
  MADRE    @map("Madre")
  HIJO     @map("Hijo")
  HERMANO  @map("Hermano")
  OTRO     @map("Otro")
}

enum Periodicidad {
  MENSUAL   @map("Mensual")
  ANUAL     @map("Anual")
}

// =============================================================================
// MODELOS BASE
// =============================================================================

model Localidad {
  id           Int         @id @default(autoincrement()) @map("id_localidad")
  codigoPostal String      @map("codigo_postal")
  nombre       String
  domicilios   Domicilio[]

  @@map("localidades")
}

model Domicilio {
  id           Int          @id @default(autoincrement()) @map("id_domicilio")
  calle        String
  numero       String
  piso         String?
  departamento String?
  localidadId  Int          @map("id_localidad")
  localidad    Localidad    @relation(fields: [localidadId], references: [id])
  deportistas  Deportista[]

  @@map("domicilios")
}





model Disciplina {
  id            Int          @id @default(autoincrement()) @map("id_disciplina")
  nombre        String       @unique
  descripcion   String?
  precioMensual Decimal      @map("precio_mensual") @db.Decimal(10, 2)
  activa        Boolean      @default(true)
  deportistas   Deportista[]
  cuotas        Cuota[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("disciplinas")
}

// =============================================================================
// USUARIOS Y AUTENTICACIÓN
// =============================================================================

model CuentaUsuario {
  id              Int             @id @default(autoincrement()) @map("id_cuenta")
  email           String          @unique
  password        String
  rol             Rol             @default(DEPORTISTA)
  activo          Boolean         @default(true)
  intentosFallidos Int            @default(0) @map("intentos_fallidos")
  bloqueadoHasta  DateTime?       @map("bloqueado_hasta")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deportista      Deportista?
  administrativo  Administrativo?

  @@map("cuentas_usuario")
}

model Administrativo {
  id        Int           @id @default(autoincrement()) @map("id_administrativo")
  nombre    String
  apellido  String
  dni       String        @unique
  cuentaId  Int           @unique @map("id_cuenta")
  cuenta    CuentaUsuario @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("administrativos")
}

// =============================================================================
// DEPORTISTAS
// =============================================================================

model Deportista {
  id            Int                       @id @default(autoincrement()) @map("id_deportista")
  nombre        String
  apellido      String
  dni           String                    @unique
  fechaNac      DateTime                  @map("fecha_nac")
  categoria     String?
  obraSocial    String?                   @map("obra_social")
  estado        EstadoDeportista          @default(AL_DIA)
  disciplinaId  Int                       @map("id_disciplina")
  disciplina    Disciplina                @relation(fields: [disciplinaId], references: [id])
  cuentaId      Int                       @unique @map("id_cuenta")
  cuenta        CuentaUsuario             @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  domicilioId   Int                       @map("id_domicilio")
  domicilio     Domicilio                 @relation(fields: [domicilioId], references: [id])
  enfermedades  String?
  telefonos     String?
  pagos         Pago[]
  cuotas        Cuota[]
  grupoFamiliar GrupoFamiliarIntegrante[]
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@map("deportistas")
}

// =============================================================================
// GRUPOS FAMILIARES
// =============================================================================

model GrupoFamiliar {
  id           Int                       @id @default(autoincrement()) @map("id_grupo_familiar")
  nombre       String
  integrantes  GrupoFamiliarIntegrante[]
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  @@map("grupos_familiares")
}

model GrupoFamiliarIntegrante {
  grupoId      Int           @map("id_grupo_familiar")
  deportistaId Int           @map("id_deportista")
  vinculo      Vinculo
  esPrincipal  Boolean       @default(false) @map("es_principal")
  grupo        GrupoFamiliar @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  deportista   Deportista    @relation(fields: [deportistaId], references: [id], onDelete: Cascade)

  @@id([grupoId, deportistaId])
  @@map("grupo_familiar_integrantes")
}

// =============================================================================
// CUOTAS Y PAGOS
// =============================================================================

model Cuota {
  id               Int          @id @default(autoincrement()) @map("id_cuota")
  nroCuota         Int          @map("nro_cuota")
  monto            Decimal      @db.Decimal(10, 2)
  fechaEmision     DateTime     @map("fecha_emision")
  fechaVencimiento DateTime     @map("fecha_vencimiento")
  estadoCuota      EstadoCuota  @default(PENDIENTE) @map("estado_cuota")
  periodicidad     Periodicidad @default(MENSUAL)
  disciplinaId     Int          @map("id_disciplina")
  disciplina       Disciplina   @relation(fields: [disciplinaId], references: [id])
  deportistaId     Int          @map("id_deportista")
  deportista       Deportista   @relation(fields: [deportistaId], references: [id], onDelete: Cascade)
  pagos            Pago[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([deportistaId, nroCuota, disciplinaId])
  @@map("cuotas")
}

model Pago {
  id                 Int         @id @default(autoincrement()) @map("id_pago")
  fechaPago          DateTime    @map("fecha_pago")
  monto              Decimal     @db.Decimal(10, 2)
  estadoPago         EstadoPago  @default(PENDIENTE) @map("estado_pago")
  medioPago          String?     @map("medio_pago")
  linkComprobante    String?     @map("link_comprobante")
  mercadoPagoId      String?     @unique @map("mercado_pago_id")
  mercadoPagoStatus  String?     @map("mercado_pago_status")
  cuotaId            Int         @map("id_cuota")
  cuota              Cuota       @relation(fields: [cuotaId], references: [id])
  deportistaId       Int         @map("id_deportista")
  deportista         Deportista  @relation(fields: [deportistaId], references: [id], onDelete: Cascade)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@map("pagos")
}

// =============================================================================
// AUDITORÍA
// =============================================================================

model AuditoriaAcceso {
  id        Int      @id @default(autoincrement())
  cuentaId  Int      @map("id_cuenta")
  accion    String
  ip        String?
  userAgent String?  @map("user_agent")
  exitoso   Boolean  @default(true)
  mensaje   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("auditoria_accesos")
}

model AuditoriaCambios {
  id          Int      @id @default(autoincrement())
  cuentaId    Int      @map("id_cuenta")
  entidad     String
  entidadId   Int      @map("entidad_id")
  accion      String
  datosAntes  String?  @map("datos_antes") @db.Text
  datosDespues String? @map("datos_despues") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("auditoria_cambios")
}
