// Define tu datasource y generator aquí (ej. PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoDeportista {
  AL_DIA
  EN_DEUDA
  MOROSA
  INACTIVA
}

model Localidad {
  id_localidad Int         @id @default(autoincrement())
  codigoPostal Int
  nombre       String      @db.VarChar(50)
  domicilios   Domicilio[]
}

model Domicilio {
  id_domicilio Int          @id @default(autoincrement())
  id_localidad Int
  localidad    Localidad    @relation(fields: [id_localidad], references: [id_localidad])
  deportistas  Deportista[]
}

model CuentaUsuario {
  id_cuenta      Int             @id @default(autoincrement())
  mail           String          @unique @db.VarChar(50)
  contrasena     String          @db.VarChar(255) // Increased for bcrypt hash
  deportista     Deportista?
  administrativo Administrativo?
}

model Administrativo {
  id_administrativo Int           @id @default(autoincrement())
  nombre            String        @db.VarChar(50)
  apellido          String        @db.VarChar(50)
  dni               Int           @unique
  // Relación inferida 1:1 con CuentaUsuario (basado en la línea del diagrama)
  id_cuenta         Int           @unique
  cuenta            CuentaUsuario @relation(fields: [id_cuenta], references: [id_cuenta])
}

model Deportista {
  id_deportista Int              @id @default(autoincrement())
  estado        EstadoDeportista
  categoria     String           @db.VarChar(50)
  fechaNac      DateTime
  obraSocial    String           @db.VarChar(50)
  nombre        String           @db.VarChar(50)
  apellido      String           @db.VarChar(50)
  dni           Int              @unique

  // Campos opcionales
  sexo       String? @db.VarChar(20)
  fotoCarnet String? @db.VarChar(255) // URL de la imagen

  // Relaciones (FKs)
  id_disciplina Int
  disciplina    Disciplina @relation(fields: [id_disciplina], references: [id_disciplina])

  id_cuenta Int           @unique // 1:1 con Cuenta
  cuenta    CuentaUsuario @relation(fields: [id_cuenta], references: [id_cuenta])

  id_domicilio Int?
  domicilio    Domicilio? @relation(fields: [id_domicilio], references: [id_domicilio])

  // Colecciones
  telefonos    Telefono[]
  cuotas       Cuota[]
  pagos        Pago[]
  enfermedades Enfermedad[] // Relación implícita N:M
}

model Enfermedad {
  id_enfermedad Int          @id @default(autoincrement())
  nombre        String       @db.VarChar(50)
  deportistas   Deportista[] // Prisma crea la tabla intermedia automáticamente
}

model Telefono {
  id_telefono   String     @id @default(uuid()) // El diagrama dice varchar, asumo UUID
  numero        Int
  // Relación inferida: El diagrama conecta Telefono a Deportista, 
  // por lo que Telefono necesita la FK.
  id_deportista Int
  deportista    Deportista @relation(fields: [id_deportista], references: [id_deportista])
}

model Disciplina {
  id_disciplina Int          @id @default(autoincrement())
  nombre        String       @db.VarChar(50)
  precioMensual Float // O Decimal si prefieres exactitud financiera
  deportistas   Deportista[]
  cuotas        Cuota[]
}

model Cuota {
  id_cuota         Int      @id @default(autoincrement())
  monto            Decimal  @db.Money // Mapeo de tipo 'money'
  fechaVencimiento DateTime
  estadoCuota      String   @db.VarChar(50)
  nroCuota         Int
  fechaEmision     DateTime
  mes              String?  @db.VarChar(20) // e.g. "ENERO", "FEBRERO"

  id_disciplina Int
  disciplina    Disciplina @relation(fields: [id_disciplina], references: [id_disciplina])

  deportista_id Int
  deportista    Deportista @relation(fields: [deportista_id], references: [id_deportista])

  pagos Pago[]
}

model Pago {
  id_pago         Int      @id @default(autoincrement())
  fechaPago       DateTime
  estadoPago      String   @db.VarChar(50)
  linkComprobante String?  @db.VarChar(50) // Puede ser opcional

  id_cuota Int
  cuota    Cuota @relation(fields: [id_cuota], references: [id_cuota])

  id_deportista Int
  deportista    Deportista @relation(fields: [id_deportista], references: [id_deportista])
}
