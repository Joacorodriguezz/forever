# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# BASE DE DATOS (PostgreSQL via Supabase)
# =============================================================================
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Ejemplo Supabase: postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/deportistas_db?schema=public"

# =============================================================================
# AUTENTICACIÓN JWT
# =============================================================================
# Genera un secret seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="tu-secret-key-super-segura-aqui-cambiar-en-produccion"
JWT_EXPIRES_IN="7d"

# =============================================================================
# MERCADO PAGO
# =============================================================================
# Obtener desde: https://www.mercadopago.com.ar/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxxxxxx-xxxxxxxx-xxxxxxxx-xxxxxxxx"
# URL base para webhooks (cambiar en producción)
MERCADOPAGO_SUCCESS_URL="http://localhost:3000/pagos/success"
MERCADOPAGO_FAILURE_URL="http://localhost:3000/pagos/failure"
MERCADOPAGO_PENDING_URL="http://localhost:3000/pagos/pending"
MERCADOPAGO_WEBHOOK_URL="http://localhost:3000/api/pagos/webhook"

# =============================================================================
# FRONTEND URL (CORS)
# =============================================================================
FRONTEND_URL="http://localhost:5173"
# Para múltiples URLs separar con comas: http://localhost:5173,https://tudominio.com

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================
# Número máximo de intentos de login antes de bloquear temporalmente
MAX_LOGIN_ATTEMPTS=5
# Tiempo de bloqueo en minutos
LOGIN_BLOCK_TIME=15

# =============================================================================
# CONFIGURACIÓN DE REPORTES (OPCIONAL)
# =============================================================================
# Directorio para almacenar PDFs/archivos temporales
REPORTS_DIR="./uploads/reports"
# Logo del club para los reportes
CLUB_LOGO_PATH="./assets/logo.png"
CLUB_NAME="Club Deportivo Forever"

# =============================================================================
# LOGS Y MONITOREO (OPCIONAL)
# =============================================================================
LOG_LEVEL="info"
LOG_DIR="./logs"

# =============================================================================
# REDIS (OPCIONAL - Para caché)
# =============================================================================
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD=""
# REDIS_DB=0
