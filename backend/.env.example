NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Para Supabase, usa la URL completa de conexión de tu proyecto
# Si usas connection pooling (pooler.supabase.com), agrega ?pgbouncer=true
# Formato directo: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
# Formato pooler: postgresql://postgres:[PASSWORD]@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=2h

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here