# ===========================================
# CONFIGURACION DEL SERVIDOR
# ===========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===========================================
# BASE DE DATOS (Supabase PostgreSQL)
# ===========================================
# Formato con connection pooling (recomendado):
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ===========================================
# JWT (Autenticacion)
# ===========================================
JWT_SECRET=tu-clave-secreta-muy-larga-y-segura
JWT_EXPIRES_IN=2h

# ===========================================
# SUPABASE (Storage para comprobantes)
# ===========================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
